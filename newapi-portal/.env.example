DATABASE_URL="postgresql://newapi:change-me@postgres:5432/new-api?schema=newapi_portal"
REDIS_URL="redis://:change-me@redis:6379/1"
AUTH_SECRET="replace-with-at-least-32-characters"
APP_URL="http://localhost:3000"

# Official or deployed NewAPI endpoint used by this portal.
NEWAPI_BASE_URL="http://newapi:3000"
# Public NewAPI base URL shown in client-side dashboard links. This is inlined at build time.
NEXT_PUBLIC_NEWAPI_BASE_URL="http://localhost:3000"
NEWAPI_ADMIN_TOKEN="replace-me"
NEWAPI_ADMIN_USER_ID="1"

# Image playground iframe base URL (independent gpt_image_playground deployment).
# NEXT_PUBLIC_* is inlined at build time; leave empty to show the configuration prompt.
NEXT_PUBLIC_IMAGE_PLAYGROUND_URL=
# Runtime CORS allowlist for image playground calls back to this portal. Prefer the explicit
# origin allowlist in production; comma-separated origins are supported.
IMAGE_PLAYGROUND_ALLOWED_ORIGIN=
# Optional runtime playground URL used as a CORS fallback when ALLOWED_ORIGIN is empty.
IMAGE_PLAYGROUND_URL=

# NewAPI quota amounts are integer quota units passed to NewAPI.
REGISTER_QUOTA="100000"
CHECKIN_QUOTA="1000"
INVITE_REWARD_QUOTA="5000"

# E2E / screenshot test account (see docs/test-deploy-easyapi-portal.md)
E2E_BASE_URL="https://test.easyapi.work"
E2E_PORTAL_IDENTIFIER="scr@easyapi.work"
E2E_PORTAL_PASSWORD="ScreenshotTest123!"
SEED_EMAIL="scr@easyapi.work"
SEED_PASSWORD="ScreenshotTest123!"
