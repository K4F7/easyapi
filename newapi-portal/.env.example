DATABASE_URL="postgresql://newapi:change-me@postgres:5432/new-api?schema=newapi_portal"
REDIS_URL="redis://:change-me@redis:6379/1"
AUTH_SECRET="replace-with-at-least-32-characters"
APP_URL="http://localhost:3000"

# Official or deployed NewAPI endpoint used by this portal.
NEWAPI_BASE_URL="http://newapi:3000"
# Public NewAPI base URL shown in dashboard copy-paste links only (inlined at build time).
# BFF upstream uses NEWAPI_BASE_URL above, not this value.
NEXT_PUBLIC_NEWAPI_BASE_URL="https://easyapi.work"
# Optional: ops/seed scripts only (e.g. scripts/seed-screenshot-user.mjs admin fallback).
# Not required for normal portal runtime — user flows authenticate via NewAPI directly.
NEWAPI_ADMIN_TOKEN=
NEWAPI_ADMIN_USER_ID=

# Optional NewAPI token group mapping for the portal's fixed channel tier labels.
# Leave unset to use auto/budget/free/normal/stable (NewAPI admin group names).
NEWAPI_CHANNEL_GROUP_AUTO="auto"
NEWAPI_CHANNEL_GROUP_LOW="budget"
NEWAPI_CHANNEL_GROUP_ACTIVITY="free"
NEWAPI_CHANNEL_GROUP_STANDARD="normal"
NEWAPI_CHANNEL_GROUP_PREMIUM="stable"

# Runtime-only upstream for gpt_image_playground; Portal proxies at /playground/embed/.
IMAGE_PLAYGROUND_INTERNAL_URL=

# Playground Chat uses the standard (一般) channel group. Users pick models in the UI.
# Default is "normal"; override only if the deployed NewAPI/BFF maps the standard channel differently.
PLAYGROUND_CHAT_GROUP="normal"

# Playground image generation uses the auto channel group by default.
PLAYGROUND_IMAGE_GROUP="auto"

# Optional external docs site URL (e.g. Vercel static site). When set, dashboard nav links
# open this URL in a new tab and the WIP badge is removed. Leave unset to use /dashboard/docs.
NEXT_PUBLIC_DOCS_URL=

# NewAPI quota amounts are integer quota units passed to NewAPI.
# Portal reads CNY conversion from NewAPI GET /api/status (quota_per_unit, usd_exchange_rate).
# QUOTA_PER_CNY is only used when /api/status is unavailable.
QUOTA_PER_CNY="500000"

# E2E / screenshot test account (see docs/test-deploy-easyapi-portal.md)
# Run `pnpm e2e:prepare` to seed staging user, write `.env.e2e`, and refresh auth storage.
E2E_BASE_URL="https://test.easyapi.work"
E2E_PORTAL_IDENTIFIER="scr@qq.com"
E2E_PORTAL_PASSWORD="ScreenshotTest123!"
SEED_EMAIL="scr@qq.com"
SEED_PASSWORD="ScreenshotTest123!"
