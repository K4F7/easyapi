{
  "name": "newapi-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test tests/e2e/portal-smoke.spec.ts tests/e2e/playground.spec.ts tests/e2e/register-billing.spec.ts",
    "test:e2e:checkin": "playwright test tests/e2e/checkin-diagnostics.spec.ts --trace=off --video=off",
    "test:e2e:playground": "playwright test tests/e2e/playground.spec.ts",
    "test:e2e:register-billing": "playwright test tests/e2e/register-billing.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:ui": "playwright test --ui",
    "seed:screenshot-user": "node scripts/seed-screenshot-user.mjs",
    "prepare:test-db": "node ../scripts/prepare-test-database.mjs",
    "screenshots:e2e": "playwright test tests/e2e/screenshots.spec.ts",
    "screenshots:all": "node scripts/seed-screenshot-user.mjs && playwright test tests/e2e/screenshots.spec.ts",
    "lint": "eslint .",
    "security:scan": "semgrep scan --config .semgrep.yml --config p/ci --config p/typescript --config p/javascript --config p/secrets --metrics=off --error",
    "security:supply-chain": "semgrep scan --supply-chain --metrics=off",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.4",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  }
}
