generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["newapi_portal"]
}

enum AuditActorType {
  USER
  ADMIN
  SYSTEM

  @@schema("newapi_portal")
}

model User {
  id                            String    @id @default(cuid())
  email                         String    @unique
  username                      String?   @unique
  newApiUserId                  String?   @unique @map("newapi_user_id")
  newApiAccessTokenCiphertext   String?   @map("newapi_access_token_ciphertext")
  newApiAccessTokenKeyId        String?   @map("newapi_access_token_key_id")
  newApiAccessTokenUpdatedAt    DateTime? @map("newapi_access_token_updated_at")
  lastLoginAt                   DateTime? @map("last_login_at")
  createdAt                     DateTime  @default(now()) @map("created_at")
  updatedAt                     DateTime  @updatedAt @map("updated_at")

  sessions                      Session[]
  auditLogs                     AuditLog[]

  @@map("users")
  @@schema("newapi_portal")
}

model Session {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
  @@schema("newapi_portal")
}

model AuditLog {
  id          String         @id @default(cuid())
  actorType   AuditActorType @map("actor_type")
  actorUserId String?        @map("actor_user_id")
  action      String
  targetType  String?        @map("target_type")
  targetId    String?        @map("target_id")
  ipHash      String?        @map("ip_hash")
  userAgent   String?        @map("user_agent")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  actorUser   User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("newapi_portal")
}
