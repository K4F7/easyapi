# Example openresty server block for https://image.easyapi.work
# Copy to your host (e.g. /etc/openresty/conf.d/image.easyapi.work.conf),
# adjust upstream/ssl paths, then: openresty -t && openresty -s reload
#
# See docs/image-playground-security.md for apply steps and verification.

upstream image_playground_upstream {
    # gpt_image_playground container or static host
    server 127.0.0.1:8080;
    keepalive 8;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name image.easyapi.work;

    # ssl_certificate     /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://image_playground_upstream;

        proxy_hide_header Referrer-Policy;
        include /etc/openresty/snippets/image-playground-security-headers.conf;
    }
}

# Optional: redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name image.easyapi.work;
    return 301 https://$host$request_uri;
}
